<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#2E7D32">

    <!-- App Logo -->
    <ImageView
        android:id="@+id/imgSplashLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="App Logo"
        android:layout_marginBottom="24dp"/>

    <!-- App Name -->
    <TextView
        android:id="@+id/tvSplashAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SaveSmart"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="8dp"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Track Today. Prevent Waste Tomorrow. 🛒"
        android:textColor="#C8E6C9"
        android:textSize="14sp"
        android:layout_marginBottom="60dp"/>

    <!-- Loading dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="40dp">

        <TextView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_white"
            android:layout_marginHorizontal="4dp"/>

        <TextView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_white_alpha"
            android:layout_marginHorizontal="4dp"/>

        <TextView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_white"
            android:layout_marginHorizontal="4dp"/>

    </LinearLayout>

</LinearLayout>