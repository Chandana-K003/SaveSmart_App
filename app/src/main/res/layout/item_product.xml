<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Name + Days Left badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvProductName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Product Name"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvDaysLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="30d left"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="#2E7D32"
                android:background="@drawable/badge_good"/>

        </LinearLayout>
        <!-- Add this INSIDE your existing card layout, after tvDaysLeft -->
        <Button
            android:id="@+id/btnDisposalTip"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="♻️ How to dispose"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <LinearLayout
            android:id="@+id/disposalLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#F1F8E9"
            android:padding="10dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvDisposalTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="12sp"
                android:textColor="#33691E" />
        </LinearLayout>

        <!-- Row 2: Expiry Date -->
        <TextView
            android:id="@+id/tvExpiryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Expires: 01 Jan 2026"
            android:textColor="#C62828"
            android:textSize="14sp"/>

        <!-- Row 3: Category + Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Category"
                android:textColor="#757575"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvDeleteBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗑 Delete"
                android:textColor="#C62828"
                android:textSize="12sp"
                android:padding="6dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
        <Button
            android:id="@+id/btnBuy"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:text="🛒 Buy Again"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone"/>

    </LinearLayout>
    <!-- Disposal tip button — shown only for expired items -->

</com.google.android.material.card.MaterialCardView>